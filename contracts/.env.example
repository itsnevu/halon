# ─── Deploy to Robinhood Chain ───────────────────────────────────────────────
# Deployer key (funded with ETH on Robinhood Chain — ETH is the gas token).
PRIVATE_KEY=

# RPC endpoints. Public RPCs are rate-limited; prefer an Alchemy endpoint.
#   Public mainnet:  https://rpc.mainnet.chain.robinhood.com
#   Public testnet:  https://rpc.testnet.chain.robinhood.com
#   Alchemy example: https://robinhood-testnet.g.alchemy.com/v2/<API_KEY>
RHC_RPC_URL=https://rpc.mainnet.chain.robinhood.com
RHC_TESTNET_RPC_URL=https://rpc.testnet.chain.robinhood.com

# Blockscout verification (usually no key needed; leave blank if so).
RHC_EXPLORER_API_KEY=

# ─── Deploy commands ─────────────────────────────────────────────────────────
# Testnet (chain 46630):
#   forge script script/DeployProofOfWork.s.sol \
#     --rpc-url robinhood_testnet --broadcast --private-key $PRIVATE_KEY
#
# Mainnet (chain 4663):
#   forge script script/DeployProofOfWork.s.sol \
#     --rpc-url robinhood --broadcast --private-key $PRIVATE_KEY
