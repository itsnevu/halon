# ── StepFun LLM (OpenAI-compatible) ──────────────────────────────
# Leave STEPFUN_API_KEY blank to run on the deterministic heuristic fallback.
# IMPORTANT: STEPFUN_BASE_URL must match the region your key was issued in.
#   Global console: https://platform.stepfun.ai  ->  https://api.stepfun.ai/v1
#   China  console: https://platform.stepfun.com ->  https://api.stepfun.com/v1
STEPFUN_API_KEY=
STEPFUN_MODEL=step-3.5-flash
STEPFUN_BASE_URL=https://api.stepfun.ai/v1

# ── API auth & limits ────────────────────────────────────────────
# When set, callers must send this as the X-API-Key header. Unset = open (dev).
AI_AGENT_API_KEY=
# Comma-separated allowed browser origins. "*" for local dev.
ALLOWED_ORIGINS=*
APPROVAL_THRESHOLD=80
MAX_UPLOAD_BYTES=10485760

# ── On-chain relayer ─────────────────────────────────────────────
RPC_URL=http://127.0.0.1:8545
# The key that holds the AI-agent relayer role. Required in any real deploy.
RELAYER_PRIVATE_KEY=
# Set to "true" ONLY for local Anvil to allow the well-known dev key fallback.
RELAYER_ALLOW_DEV_KEY=false
