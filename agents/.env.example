# ── CROO CAP ────────────────────────────────────────────────────────────────
# Still guesses. `Config.baseURL` is required and the SDK ships no default, so a
# wrong value fails at the first request, not at startup. See README §Open questions.
CROO_API_URL=https://api.croo.network
CROO_WS_URL=wss://api.croo.network/ws

# The SDK defaults to Base *mainnet* and there is no testnet anywhere in the bundle.
# Everything below spends real money. Demo with $1 of coverage, not $100.
CROO_RPC_URL=https://mainnet.base.org
USDC_ADDRESS=0x833589fCD6eDb6E08f4c7C32D4f71b54bdA02913

# ── One SDK-Key per agent, issued from the CROO Dashboard ───────────────────
SDK_KEY_CLIENT=
SDK_KEY_WORKER=
SDK_KEY_UNDERWRITER_A=
SDK_KEY_UNDERWRITER_B=

# The Watcher needs a key that is a party to the insured orders. In the demo that
# is the Client's — Sentinel is not a party to the job it insures.
WATCHER_SDK_KEY=

# ── Service ids, from listing the services in the Dashboard ─────────────────
# The two coverage services need `require_fund_transfer=true`, which is NOT
# settable through the SDK. If the Dashboard does not expose that toggle, the
# atomic premium-into-pool design does not work. Verify this first.
SERVICE_ID_WORKER=
SERVICE_ID_COVERAGE_A=
SERVICE_ID_REINSURANCE_B=

# CAP agent id of the worker being insured, e.g. cap:agent:aurora
WORKER_AGENT_ID=

# ── On-chain identities ─────────────────────────────────────────────────────
# These are NOT the agents' CAP wallets. CAP custodies those against the SDK-Key;
# we cannot sign with them. These keys hold UNDERWRITER_ROLE / CAPITAL_ROLE and
# sign bindDirect, bindTreaty, attachReinsurance.
DEPLOYER_PRIVATE_KEY=
UNDERWRITER_A_PRIVATE_KEY=
UNDERWRITER_B_PRIVATE_KEY=

# Signs the EIP-712 attestation and relays the discharge. Needs ETH for gas.
ATTESTOR_PRIVATE_KEY=

# ── Deploy-time addresses (used by contracts/script/Deploy.s.sol) ───────────
UNDERWRITER_A_ADDRESS=
UNDERWRITER_B_ADDRESS=
ATTESTOR_ADDRESS=
# Sentinel's *CAP custodial wallet*. `drawCededPremium` pays the ceded premium here,
# because that is the account CAP debits when Sentinel pays the reinsurance order.
UNDERWRITER_A_CAP_WALLET=

BASE_RPC_URL=https://mainnet.base.org
BASESCAN_API_KEY=

# ── Contract addresses (fill in from the deploy script's output) ────────────
RISK_ENGINE=
POLICY_POOL_A=
POLICY_POOL_B=
CLAIMS_ADJUDICATOR=

# ── Demo knobs ──────────────────────────────────────────────────────────────
# Probability the worker silently drops a paid job.
WORKER_FAIL_RATE=0
DEMO_COVERAGE_USD=1
DEMO_TENOR_HOURS=24
# Reject the job to trigger a claim. The Watcher will refuse if the worker
# actually delivered — that is the point, not a bug.
DEMO_REJECT=false
DEMO_REJECT_AFTER_SECONDS=20
